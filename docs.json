{
  "$schema": "https://mintlify.com/docs.json",
  "name": "NodePad",
  "theme": "willow",
  "colors": {
    "primary": "#2563eb",
    "light": "#f8fafc",
    "dark": "#0f172a"
  },
  "logo": {
    "light": "/logo-wordmark-light.svg",
    "dark": "/logo-wordmark-dark.svg"
  },
  "favicon": {
    "light": "/logo-icon-light.svg",
    "dark": "/logo-icon-dark.svg"
  },
  "font": {
    "headings": {
      "family": "Outfit"
    },
    "body": {
      "family": "Outfit"
    }
  },
  "background": {
    "decoration": "grid",
    "color": {
      "light": "#f8fafc",
      "dark": "#0f172a"
    }
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Join beta",
      "href": "https://node-pad.com/beta"
    }
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": "dark"
  },
  "navigation": {
    "groups": [
      {
        "group": "Start here",
        "pages": [
          "introduction",
          "quickstart",
          "beta-access"
        ]
      },
      {
        "group": "Core workflow",
        "pages": [
          "concepts/canvas",
          "concepts/nodes",
          "concepts/forking",
          "concepts/merging",
          "concepts/references",
          "concepts/sticky-notes"
        ]
      },
      {
        "group": "Models and settings",
        "pages": [
          "models/overview",
          "models/per-message-selection",
          "models/bring-your-own-keys"
        ]
      },
      {
        "group": "Use cases",
        "pages": [
          "use-cases/research",
          "use-cases/engineering",
          "use-cases/writing"
        ]
      },
      {
        "group": "Enterprise",
        "pages": [
          "enterprise/overview",
          "enterprise/self-hosting",
          "enterprise/operations/install",
          "enterprise/operations/upgrade",
          "enterprise/operations/air-gapped"
        ]
      },
      {
        "group": "Changelog",
        "pages": [
          "changelog"
        ]
      }
    ]
  },
  "footer": {
    "socials": {}
  }
}
